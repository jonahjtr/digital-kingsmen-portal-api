{
  "name": "digital-kingsmen-portal-api",
  "version": "1.0.0",
  "description": "API for Digital Kingsmen client portal",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev",
    "dev:node": "ENABLE_SWAGGER=true tsx watch src/index.ts",
    "build": "tsc",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:cf": "npm run cf:migrate:remote && npm run deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:cf": "CF_SEED=1 tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "cf:migrate:local": "wrangler d1 migrations apply portal-db --local",
    "cf:migrate:remote": "wrangler d1 migrations apply portal-db --remote",
    "cf:setup:local": "npm run cf:migrate:local && npm run db:seed:cf",
    "cf:seed:remote": "wrangler d1 export portal-db --local --output /tmp/portal-seed-data.sql --no-schema -y && grep -v 'INSERT INTO \"d1_migrations\"' /tmp/portal-seed-data.sql > /tmp/portal-seed-remote.sql && wrangler d1 execute portal-db --remote --file=/tmp/portal-seed-remote.sql -y",
    "cf:types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "wrangler": "wrangler",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami"
  },
  "keywords": [
    "api",
    "portal",
    "digital-kingsmen"
  ],
  "author": "Digital Kingsmen",
  "license": "ISC",
  "dependencies": {
    "@cloudflare/containers": "^0.3.4",
    "@prisma/adapter-d1": "^6.19.3",
    "@prisma/client": "^6.3.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260516.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/yamljs": "^0.2.34",
    "prisma": "^6.3.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "wrangler": "^4.92.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
