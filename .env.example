# Local Node dev (npm run dev:node) — SQLite file
DATABASE_URL=file:./prisma/dev.db
PORT=3003
NODE_ENV=development

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173,http://localhost:8787

# local | r2 (r2 requires wrangler + R2 bucket binding)
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

NUDGE_COOLDOWN_MINUTES=240

# Invite emails (optional — Resend https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Digital Kingsmen <onboarding@resend.dev>
APP_URL=http://localhost:5173

# Cloudflare: copy .dev.vars.example → .dev.vars and use `npm run dev` (wrangler)
