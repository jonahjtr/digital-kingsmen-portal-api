# Use any port from 3001–3005 (3003 is a good default)
PORT=3003
NODE_ENV=development

# Database
# Docker Compose (default in docker-compose.yml):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digital_kingsmen_portal
# Homebrew PostgreSQL on macOS (use your macOS username, often no password):
DATABASE_URL=postgresql://YOUR_USER@localhost:5432/digital_kingsmen_portal

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# Storage
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
# S3-compatible (future)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

# Nudge cooldown in minutes
NUDGE_COOLDOWN_MINUTES=240
